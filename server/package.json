{
  "name": "dna-server",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build-cpp": "powershell -ExecutionPolicy Bypass -File ../cpp/build.ps1",
    "build-frontend": "cd ../frontend && npm ci && npm run build",
    "start:prod": "npm run build-cpp && npm run build-frontend && node src/index.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "body-parser": "^1.20.2",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  }
}
